# Bandwidth controls
PROFILE_IMAGE_MAX_BYTES=3145728
SELFIE_IMAGE_MAX_BYTES=1048576
OPTIMIZED_PROFILE_MAX_DIMENSION=768
OPTIMIZED_PROFILE_JPEG_QUALITY=75
